---
import BottomNav from "../../presentation/components/BottomNav.vue";
import Header from "../../presentation/components/Header.astro";
import EditProductForm from "../../presentation/components/EditProductForm.vue";
import "../../styles/global.css";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/my-products");
}

const marketplaceName = import.meta.env.PUBLIC_MARKETPLACE_NAME || "Naya";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar Producto - {marketplaceName}</title>
  </head>
  <body class="bg-[#FDFCFB] min-h-screen pb-24">
    <!-- Auth Guard en el cliente -->
    <div id="auth-guard" class="hidden">
      <Header leftAction="back-my-products" rightAction="cart" />

      <main class="max-w-3xl mx-auto px-6 py-12">
        <EditProductForm client:only="vue" productId={id} />
      </main>
    </div>

    <script>
      import { getAuth, onAuthStateChanged } from "firebase/auth";
      import { app } from "../../lib/firebase";

      const auth = getAuth(app);
      onAuthStateChanged(auth, (user) => {
        if (!user) {
          // Redirigir al login con el parámetro 'next'
          const currentPath = window.location.pathname;
          window.location.href = `/login?next=${encodeURIComponent(currentPath)}`;
        } else {
          // Mostrar contenido
          document.getElementById("auth-guard")?.classList.remove("hidden");
        }
      });
    </script>

    <BottomNav client:only="vue" />
  </body>
</html>
