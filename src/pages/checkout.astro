---
import CheckoutView from "../presentation/components/CheckoutView.vue";
import BottomNav from "../presentation/components/BottomNav.vue";
import Header from "../presentation/components/Header.astro";
import "../styles/global.css";

const marketplaceName = import.meta.env.PUBLIC_MARKETPLACE_NAME || "Naya";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout - {marketplaceName}</title>
  </head>
  <body class="bg-[#FDFCFB] min-h-screen pb-24">
    <Header leftAction="back" rightAction="none" />

    <main class="max-w-7xl mx-auto px-6 py-8">
      <h1 class="text-3xl font-black text-gray-900 mb-8">Finalizar Compra</h1>
      <CheckoutView client:only="vue" />
    </main>

    <!-- Navegacion Inferior -->
    <BottomNav client:only="vue" />
  </body>
</html>
