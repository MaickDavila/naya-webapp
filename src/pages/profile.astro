---
import BottomNav from '../presentation/components/BottomNav.vue';
import Header from '../presentation/components/Header.astro';
import UserProfileView from '../presentation/components/UserProfileView.vue';
import '../styles/global.css';

const marketplaceName = import.meta.env.PUBLIC_MARKETPLACE_NAME || 'Naya';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Mi Perfil - {marketplaceName}</title>
	</head>
	<body class="bg-[#FDFCFB] min-h-screen pb-24">
		<!-- Auth Guard en el cliente -->
		<div id="auth-guard" class="hidden">
			<Header leftAction="back-home" rightAction="cart" />

			<main class="max-w-5xl mx-auto px-6 py-12">
				<UserProfileView client:only="vue" />
			</main>
		</div>

		<script>
			import { getAuth, onAuthStateChanged } from "firebase/auth";
			import { app } from "../lib/firebase";

			const auth = getAuth(app);
			onAuthStateChanged(auth, (user) => {
				if (!user) {
					const currentPath = window.location.pathname;
					window.location.href = `/login?next=${encodeURIComponent(currentPath)}`;
				} else {
					document.getElementById('auth-guard')?.classList.remove('hidden');
				}
			});
		</script>

		<BottomNav client:only="vue" />
	</body>
</html>
