---
import { FirestoreUserRepository } from "../../infrastructure/repositories/FirestoreUserRepository";
import { FirestoreProductRepository } from "../../infrastructure/repositories/FirestoreProductRepository";
import { FirestoreReviewRepository } from "../../infrastructure/repositories/FirestoreReviewRepository";
import { GetUserById } from "../../application/use-cases/GetUserById";
import SellerProfileView from "../../presentation/components/SellerProfileView.vue";
import BottomNav from "../../presentation/components/BottomNav.vue";
import Header from "../../presentation/components/Header.astro";
import "../../styles/global.css";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/404");
}

const userRepo = new FirestoreUserRepository();
const productRepo = new FirestoreProductRepository();
const reviewRepo = new FirestoreReviewRepository();

const getUserById = new GetUserById(userRepo);
const seller = await getUserById.execute(id);

if (!seller) {
  return Astro.redirect("/404");
}

const sellerProducts = await productRepo.getBySellerId(id);
const sellerReviews = await reviewRepo.getByReviewedUserId(id);
const marketplaceName = import.meta.env.PUBLIC_MARKETPLACE_NAME || "Naya";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Perfil de {seller.name} - {marketplaceName}</title>
  </head>
  <body class="bg-[#FDFCFB] min-h-screen pb-24">
    <Header leftAction="back" rightAction="cart" />

    <main class="max-w-7xl mx-auto px-6 py-12">
      <SellerProfileView
        client:load
        seller={seller}
        products={sellerProducts}
        reviews={sellerReviews}
      />
    </main>

    <!-- Navegación Inferior -->
    <BottomNav client:only="vue" />
  </body>
</html>
