---
import BottomNav from "../presentation/components/BottomNav.vue";
import Header from "../presentation/components/Header.astro";
import SellForm from "../presentation/components/SellForm.vue";
import "../styles/global.css";

// Lógica de redirección a Login si no hay sesión (en el cliente)
---

<script>
  // Verificación simple en el cliente antes de montar nada
  const authInitialized = false;
  // Esto lo manejaremos mejor con un componente Vue que chequee el estado de Firebase
</script>

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vender Producto - Naya</title>
  </head>
  <body class="bg-[#FDFCFB] min-h-screen pb-24">
    <!-- Auth Guard en el cliente -->
    <div id="auth-guard" class="hidden">
      <Header leftAction="back-home" rightAction="cart" />

      <main class="max-w-3xl mx-auto px-6 py-12">
        <SellForm client:only="vue" />
      </main>
    </div>

    <script>
      import { getAuth, onAuthStateChanged } from "firebase/auth";
      import { app } from "../lib/firebase";

      const auth = getAuth(app);
      onAuthStateChanged(auth, (user) => {
        if (!user) {
          // Redirigir al login con el parámetro 'next'
          const currentPath = window.location.pathname;
          window.location.href = `/login?next=${encodeURIComponent(currentPath)}`;
        } else {
          // Mostrar contenido
          document.getElementById("auth-guard")?.classList.remove("hidden");
        }
      });

      // Los eventos success y error se manejan dentro del componente SellForm
      // No es necesario manejarlos aquí ya que el componente redirige automáticamente
    </script>

    <BottomNav client:only="vue" />
  </body>
</html>
