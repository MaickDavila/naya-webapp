---
import BottomNav from '../presentation/components/BottomNav.vue';
import CartList from '../presentation/components/CartList.vue';
import Header from '../presentation/components/Header.astro';
import '../styles/global.css';

const marketplaceName = import.meta.env.PUBLIC_MARKETPLACE_NAME || 'Naya';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Tu Bolsa - {marketplaceName}</title>
	</head>
	<body class="bg-[#FDFCFB] min-h-screen pb-24">
		<Header leftAction="back-home" rightAction="cart" />

		<main class="max-w-lg mx-auto px-6 py-6">
			<CartList client:load />
		</main>

		<!-- Navegación Inferior -->
		<BottomNav client:only="vue" />
	</body>
</html>
